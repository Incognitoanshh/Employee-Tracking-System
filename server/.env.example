# ─────────────────────────────────────────
# ETS Server — Environment Variables
# Copy this file to .env and fill values
# ─────────────────────────────────────────

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ets_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT secret (strong random string use karo)
JWT_SECRET=change_this_to_a_long_random_string

# Server port
PORT=5000

# CORS — client ka origin (python client ya web)
ALLOWED_ORIGIN=http://localhost:8000

# Optional: Screenshot upload directory (default: server/uploads/screenshots)
# UPLOAD_DIR=/var/ets/screenshots
